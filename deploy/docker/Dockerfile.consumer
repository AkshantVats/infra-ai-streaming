# Multi-stage build for Go consumer.
# Build from repo root:
#   docker build -f deploy/docker/Dockerfile.consumer -t lensai/consumer:local .

FROM golang:1.25-bookworm AS builder
WORKDIR /build/consumer
COPY consumer/go.mod consumer/go.sum ./
RUN go mod download
COPY consumer/ ./
RUN CGO_ENABLED=0 go build -o /consumer ./cmd/consumer

FROM gcr.io/distroless/static-debian12:nonroot
WORKDIR /
COPY --from=builder /consumer /consumer
EXPOSE 9091
USER nonroot:nonroot
ENTRYPOINT ["/consumer"]

# Minimal dev Compose profile (fewer partitions, smaller batches).
# Used by: ./scripts/run.sh --profile dev --target compose

KAFKA_BROKERS=127.0.0.1:9092
KAFKA_TOPIC=ai_inference_events
KAFKA_DLQ_TOPIC=ai_inference_dlq
KAFKA_TOPIC_PARTITIONS=2

REDIS_URL=redis://127.0.0.1:6379
HTTP_PORT=8080
WAL_DIR=/tmp/wal

RATE_LIMIT_DEFAULT_RPS=10000
RATE_LIMIT_BURST_MULTIPLIER=2.0
BATCH_CHANNEL_CAPACITY=10000
MAX_BATCH_SIZE=1000
MAX_EVENT_AGE_MS=3600000
MAX_CONCURRENT_REQUESTS=1000

CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

KAFKA_GROUP_ID=ai-inference-consumer-dev
LOG_LEVEL=info
METRICS_PORT=9091
CLICKHOUSE_DSN=clickhouse://127.0.0.1:9000/infra_ai
REDIS_OVERFLOW_KEY=ai_inference:overflow
BATCH_SIZE=1000
FLUSH_INTERVAL=500ms
CB_FAILURE_THRESHOLD=5
CB_RESET_TIMEOUT=30s
CLICKHOUSE_INSERT_RETRIES=3
OVERFLOW_DRAIN_INTERVAL=5s
OVERFLOW_DRAIN_BATCH=5000

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# Local stack + ingestion environment template (deploy/.env)
# =============================================================================
# Copy before `docker compose` (file is gitignored after copy):
#   cp deploy/.env.example deploy/.env
#
# Compose loads this file via `env_file: .env` (paths relative to deploy/).
# From repo root, pass it for variable interpolation too:
#   docker compose --env-file deploy/.env -f deploy/docker-compose.yml up -d
#
# The ingestion crate reads the same variable names at runtime (see
# ingestion/src/config.rs). Defaults in code are localhost + /tmp — safe for
# local dev only; production must set real brokers, Redis, WAL paths, etc.
# Do not put API keys, tenant IDs, or cloud endpoints here or in source.
# =============================================================================

# -----------------------------------------------------------------------------
# Kafka / Redpanda (ingestion + compose)
# -----------------------------------------------------------------------------
# Host machine (Rust tests / future binary) with published broker port 9092:
KAFKA_BROKERS=127.0.0.1:9092
# If you add an ingestion container to this Compose file, switch to:
# KAFKA_BROKERS=redpanda:9092

KAFKA_TOPIC=ai_inference_events
KAFKA_DLQ_TOPIC=ai_inference_dlq

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379
# In-compose consumer example:
# REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# HTTP (ingestion binary — cargo run -p ingestion)
# -----------------------------------------------------------------------------
HTTP_PORT=8080

# -----------------------------------------------------------------------------
# WAL directory (local path; ingestion default in code is /tmp/wal)
# -----------------------------------------------------------------------------
WAL_DIR=/tmp/wal

# -----------------------------------------------------------------------------
# Rate limits and batching (ingestion)
# -----------------------------------------------------------------------------
RATE_LIMIT_DEFAULT_RPS=10000
RATE_LIMIT_BURST_MULTIPLIER=2.0
BATCH_CHANNEL_CAPACITY=10000
MAX_BATCH_SIZE=1000
MAX_EVENT_AGE_MS=3600000
MAX_CONCURRENT_REQUESTS=1000

# -----------------------------------------------------------------------------
# ClickHouse (official image defaults; optional overrides)
# -----------------------------------------------------------------------------
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# -----------------------------------------------------------------------------
# Go consumer (cargo run -p ingestion uses Rust vars above; consumer uses these)
# -----------------------------------------------------------------------------
# Host machine with published broker port 9092:
KAFKA_GROUP_ID=ai-inference-consumer-dev
# 8 partitions locally (32 in production — see deploy/redpanda/init-topics.sh)
KAFKA_TOPIC_PARTITIONS=8
LOG_LEVEL=info
METRICS_PORT=9091
CLICKHOUSE_DSN=clickhouse://127.0.0.1:9000/infra_ai
REDIS_OVERFLOW_KEY=ai_inference:overflow
BATCH_SIZE=1000
FLUSH_INTERVAL=500ms
CB_FAILURE_THRESHOLD=5
CB_RESET_TIMEOUT=30s
CLICKHOUSE_INSERT_RETRIES=3
OVERFLOW_DRAIN_INTERVAL=5s
OVERFLOW_DRAIN_BATCH=5000

# -----------------------------------------------------------------------------
# Prometheus / Grafana (compose services)
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
